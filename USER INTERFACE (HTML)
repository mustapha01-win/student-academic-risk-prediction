<!DOCTYPE html> <html lang="en"> <head>   <meta charset="UTF-8">   <title>Prediction Result</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>    body { background-color: #f8f9fa; }    .card { border-radius: 8px; }    .badge { font-size: 0.9rem; }  </style>
</head> <body> <div class="container mt-5">
  <div class="card p-4">    <h4 class="mb-3">Prediction Result (Ensemble )</h4>
    <table class="table table-sm">      <tr>        <th>Dataset</th>        <td>{{ dataset }}</td>      </tr>
      {% if early_prediction is defined %}      <tr>        <th>Prediction Type</th>        <td>          {% if early_prediction %}            <span class="badge bg-warning text-dark">Early Risk Prediction</span>          {% else %}            <span class="badge bg-success">Final Risk Prediction</span>          {% endif %}        </td>      </tr>      {% endif %}
      <tr>        <th>Average Risk Probability</th>        <td>{{ avg_risk }}</td>      </tr>
      <tr>        <th>Risk Label</th>        <td><strong>{{ risk_label }}</strong></td>      </tr>    </table>
    <hr>
    <h5>Individual Model Probabilities</h5>    <table class="table table-sm small">      <tr>        <th>Model</th>        <th>Probability</th>      </tr>      <tr>        <td>Random Forest (RF)</td>        <td>{{ rf_prob }}</td>      </tr>      <tr>        <td>XGBoost (XGB)</td>        <td>{{ xgb_prob }}</td>      </tr>      <tr>        <td>CART (Decision Tree)</td>        <td>{{ cart_prob }}</td>      </tr>      <tr>        <td>C5.0 (Decision Tree)</td>        <td>{{ c50_prob }}</td>      </tr>      <tr>        <td>Deep Neural Network (DNN)</td>        <td>{{ dnn_prob }}</td>      </tr>      {% if svm_prob is defined %}      <tr>        <td>Support Vector Machine (SVM)</td>        <td>{{ svm_prob }}</td>      </tr>      {% endif %}    </table>
    <hr>
    <h5>Model Explanation (LIME)</h5>    <p class="alert alert-info">      {% if lime_html is string %}        {{ lime_html }}      {% else %}        {% for line in lime_html %}          {{ line }}         {% endfor %}      {% endif %}    </p>
    <a href="/" class="btn btn-outline-primary mt-3">← Back</a>  </div>
</div> </body> </html> \`\`\`


